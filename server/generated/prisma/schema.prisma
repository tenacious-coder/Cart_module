generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model auth_tokens {
  token_id                            Int                    @id @default(autoincrement())
  user_id                             Int
  token                               String                 @db.VarChar(512)
  token_type                          auth_tokens_token_type
  expires_at                          DateTime               @db.DateTime(0)
  is_revoked                          Boolean?               @default(false)
  created_at                          DateTime?              @default(now()) @db.DateTime(0)
  created_by                          Int?
  updated_at                          DateTime?              @default(now()) @db.DateTime(0)
  updated_by                          Int?
  users_auth_tokens_created_byTousers users?                 @relation("auth_tokens_created_byTousers", fields: [created_by], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_auth_created_by")
  users_auth_tokens_updated_byTousers users?                 @relation("auth_tokens_updated_byTousers", fields: [updated_by], references: [user_id], onDelete: NoAction, onUpdate: NoAction, map: "fk_auth_updated_by")
  users_auth_tokens_user_idTousers    users                  @relation("auth_tokens_user_idTousers", fields: [user_id], references: [user_id], onDelete: Cascade, onUpdate: NoAction, map: "fk_auth_user")

  @@index([created_by], map: "fk_auth_created_by")
  @@index([updated_by], map: "fk_auth_updated_by")
  @@index([token], map: "idx_auth_token")
  @@index([user_id], map: "idx_auth_user")
}

